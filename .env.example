PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/promptbank?sslmode=disable
JWT_SECRET=dev-only-secret-change-me
JWT_EXPIRES_MINUTES=120
REDIS_ADDR=localhost:6379

