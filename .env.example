PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/promptbank?sslmode=disable
JWT_SECRET=dev-only-secret-change-me
JWT_EXPIRES_MINUTES=120
REDIS_ADDR=localhost:6379

# LLM (Gemini) — optional. Leave GEMINI_API_KEY empty to disable LLM features.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_MAX_CONCURRENT=5

# Optional: docker compose substitutes these for postgres/redis services and the API DATABASE_URL override.
# POSTGRES_DB=promptbank
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_PORT=5432
# REDIS_PORT=6379
